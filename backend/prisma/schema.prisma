generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Article {
  id            String         @id
  title         String
  slug          String         @unique
  description   String
  content       String
  category      String
  authorId      String
  publishedAt   DateTime       @default(now())
  status        ArticleStatus  @default(DRAFT)
  featured      Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime
  uniqueViews   Int            @default(0)
  viewCount     Int            @default(0)
  featuredImage String?
  User          User           @relation(fields: [authorId], references: [id])
  ArticleView   ArticleView[]
  Bookmark      Bookmark[]
  Comment       Comment[]
  Like          Like[]
  TagOnArticle  TagOnArticle[]

  @@index([authorId])
  @@index([authorId, status])
  @@index([createdAt])
  @@index([featured])
  @@index([publishedAt])
  @@index([status])
  @@index([status, publishedAt])
  @@index([uniqueViews])
  @@index([viewCount])
}

model ArticleView {
  id          String   @id
  articleId   String
  userId      String?
  visitorId   String
  ipAddress   String?
  userAgent   String?
  referrer    String?
  country     String?
  city        String?
  device      String?
  browser     String?
  os          String?
  viewedAt    DateTime @default(now())
  timeOnPage  Int?
  scrollDepth Int?
  Article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, visitorId, viewedAt])
  @@index([articleId])
  @@index([viewedAt])
  @@index([visitorId])
}

model Bookmark {
  id        String   @id
  userId    String
  articleId String
  createdAt DateTime @default(now())
  Article   Article  @relation(fields: [articleId], references: [id])
  User      User     @relation(fields: [userId], references: [id])

  @@unique([userId, articleId])
  @@index([articleId])
  @@index([userId, createdAt])
}

model Comment {
  id        String        @id
  body      String
  articleId String
  authorId  String
  status    CommentStatus @default(PENDING)
  createdAt DateTime      @default(now())
  Article   Article       @relation(fields: [articleId], references: [id])
  User      User          @relation(fields: [authorId], references: [id])

  @@index([articleId])
  @@index([authorId])
  @@index([createdAt])
  @@index([status])
}

model Like {
  id        String   @id
  articleId String
  userId    String
  createdAt DateTime @default(now())
  Article   Article  @relation(fields: [articleId], references: [id])
  User      User     @relation(fields: [userId], references: [id])

  @@unique([articleId, userId])
  @@index([articleId, createdAt])
  @@index([createdAt])
  @@index([userId])
}

model Subscription {
  id        String   @id
  email     String   @unique
  topics    String[]
  createdAt DateTime @default(now())
}

model Tag {
  id           String         @id
  name         String         @unique
  slug         String         @unique
  TagOnArticle TagOnArticle[]
}

model TagOnArticle {
  articleId String
  tagId     String
  Article   Article @relation(fields: [articleId], references: [id])
  Tag       Tag     @relation(fields: [tagId], references: [id])

  @@id([articleId, tagId])
}

model User {
  id            String     @id
  walletAddress String     @unique
  name          String?
  role          Role       @default(WRITER)
  avatarUrl     String?
  bio           String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime
  email         String?    @unique
  Article       Article[]
  Bookmark      Bookmark[]
  Comment       Comment[]
  Like          Like[]

  @@index([walletAddress])
}

enum ArticleStatus {
  DRAFT
  REVIEW
  PUBLISHED
}

enum CommentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Role {
  ADMIN
  EDITOR
  WRITER
}
