generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Article {
  id            String         @id @default(uuid())
  title         String
  slug          String         @unique
  description   String
  content       String
  category      String
  authorId      String
  publishedAt   DateTime       @default(now())
  status        ArticleStatus  @default(DRAFT)
  featured      Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  uniqueViews   Int            @default(0)
  viewCount     Int            @default(0)
  featuredImage String?
  score         Float          @default(0)
  author        User           @relation(fields: [authorId], references: [id])
  views         ArticleView[]
  bookmarks     Bookmark[]
  comments      Comment[]
  likes         Like[]
  tags          TagOnArticle[]

  @@index([authorId])
  @@index([authorId, status])
  @@index([createdAt])
  @@index([featured])
  @@index([publishedAt])
  @@index([status])
  @@index([status, publishedAt])
  @@index([status, score])
  @@index([uniqueViews])
  @@index([viewCount])
}

model ArticleView {
  id          String   @id @default(uuid())
  articleId   String
  userId      String?
  visitorId   String
  ipAddress   String?
  userAgent   String?
  referrer    String?
  country     String?
  city        String?
  device      String?
  browser     String?
  os          String?
  viewedAt    DateTime @default(now())
  timeOnPage  Int?
  scrollDepth Int?
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, visitorId, viewedAt])
  @@index([articleId])
  @@index([viewedAt])
  @@index([visitorId])
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  articleId String
  createdAt DateTime @default(now())
  article   Article  @relation(fields: [articleId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, articleId])
  @@index([articleId])
  @@index([userId, createdAt])
}

model Comment {
  id        String        @id @default(uuid())
  body      String
  articleId String
  authorId  String
  status    CommentStatus @default(PENDING)
  createdAt DateTime      @default(now())
  article   Article       @relation(fields: [articleId], references: [id])
  author    User          @relation(fields: [authorId], references: [id])

  @@index([articleId])
  @@index([articleId, createdAt]) // paginated comment queries per article
  @@index([authorId])
  @@index([createdAt])
  @@index([status])
}

model Like {
  id        String   @id @default(uuid())
  articleId String
  userId    String
  createdAt DateTime @default(now())
  article   Article  @relation(fields: [articleId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([articleId, userId])
  @@index([articleId, createdAt])
  @@index([createdAt])
  @@index([userId])
}

model Subscription {
  id        String   @id @default(uuid())
  email     String   @unique
  topics    String[]
  createdAt DateTime @default(now())
}

model Tag {
  id           String         @id @default(uuid())
  name         String         @unique
  slug         String         @unique
  usages       TagOnArticle[]
}

model TagOnArticle {
  articleId String
  tagId     String
  article   Article @relation(fields: [articleId], references: [id])
  tag       Tag     @relation(fields: [tagId], references: [id])

  @@id([articleId, tagId])
}

model User {
  id            String     @id @default(uuid())
  walletAddress String     @unique
  name          String?
  role          Role       @default(WRITER)
  avatarUrl     String?
  bio           String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  email         String?    @unique
  articles      Article[]
  bookmarks     Bookmark[]
  comments      Comment[]
  likes         Like[]

  @@index([walletAddress])
}

enum ArticleStatus {
  DRAFT
  REVIEW
  PUBLISHED
}

enum CommentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Role {
  ADMIN
  EDITOR
  WRITER
}
